{
  "name": "obsidian-confluence-git-sync",
  "version": "0.1.15",
  "description": "Obsidian plugin to publish notes to Confluence with Git as source of truth",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "test": "jest",
    "lint": "eslint src/",
    "format": "prettier --write src/"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "confluence",
    "git",
    "publish",
    "sync"
  ],
  "author": "DIAL Studio",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.20.0",
    "jest": "^29.7.0",
    "obsidian": "^1.5.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.1.0",
    "tslib": "^2.6.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "isomorphic-git": "^1.25.0",
    "js-yaml": "^4.1.0",
    "turndown": "^7.1.0"
  }
}
